{
  "name": "@ipollo/ipollowalk-workspace",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "IPOLLOWALK_DEV_MODE=1 IPOLLOWALK_ELECTRON_REMOTE_DEBUG_PORT=${IPOLLOWALK_ELECTRON_REMOTE_DEBUG_PORT:-9823} pnpm --filter @ipollowalk/desktop dev",
    "dev:electron": "IPOLLOWALK_DEV_MODE=1 pnpm --filter @ipollowalk/desktop dev:electron",
    "dev:electron:two": "IPOLLOWALK_DEV_MODE=1 node scripts/dev-two-electron-demo.mjs",
    "demo:electron": "IPOLLOWALK_DEV_MODE=1 node scripts/dev-two-electron-demo.mjs --reset",
    "demo:electron:reset": "node scripts/dev-two-electron-demo.mjs --reset-only",
    "demo:reset": "pnpm demo:electron:reset",
    "dev:sandbox": "bash .devcontainer/dev-sandbox.sh",
    "dev:ui": "IPOLLOWALK_DEV_MODE=1 pnpm --filter @ipollowalk/app dev",
    "dev:ui-demo": "pnpm --filter @ipollowalk/ui-demo dev",
    "email:dev": "pnpm --filter @ipollowalk/email dev",
    "dev:headless-web": "IPOLLOWALK_DEV_MODE=1 bun scripts/dev-headless-web.ts",
    "build": "node scripts/build.mjs",
    "build:ui": "pnpm --filter @ipollowalk/app build",
    "preview": "pnpm --filter @ipollowalk/app preview",
    "typecheck": "pnpm --filter @ipollowalk/app typecheck",
    "test:health": "pnpm --filter @ipollowalk/app test:health",
    "test:sessions": "pnpm --filter @ipollowalk/app test:sessions",
    "test:refactor": "pnpm --filter @ipollowalk/app test:refactor",
    "test:events": "pnpm --filter @ipollowalk/app test:events",
    "test:todos": "pnpm --filter @ipollowalk/app test:todos",
    "test:permissions": "pnpm --filter @ipollowalk/app test:permissions",
    "test:session-error-recovery": "pnpm --filter @ipollowalk/app test:session-error-recovery",
    "test:session-scope": "pnpm --filter @ipollowalk/app test:session-scope",
    "test:session-switch": "pnpm --filter @ipollowalk/app test:session-switch",
    "test:fs-engine": "pnpm --filter @ipollowalk/app test:fs-engine",
    "test:e2e": "pnpm --filter @ipollowalk/app test:e2e",
    "evals": "node evals/runner/run.mjs",
    "fraimz": "node evals/runner/run.mjs",
    "test:orchestrator": "pnpm --filter ipollowalk-orchestrator test:router",
    "bump:patch": "pnpm --filter @ipollowalk/app bump:patch",
    "bump:minor": "pnpm --filter @ipollowalk/app bump:minor",
    "bump:major": "pnpm --filter @ipollowalk/app bump:major",
    "bump:set": "pnpm --filter @ipollowalk/app bump:set",
    "release:review": "node scripts/release/review.mjs",
    "release:prepare": "node scripts/release/prepare.mjs",
    "release:prepare:dry": "node scripts/release/prepare.mjs --dry-run",
    "release:ship": "node scripts/release/ship.mjs",
    "release:ship:watch": "node scripts/release/ship.mjs --watch"
  },
  "devDependencies": {
    "turbo": "^2.5.5"
  },
  "packageManager": "pnpm@11.4.0"
}
