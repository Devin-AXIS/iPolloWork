{
  "name": "@ipollo/ipollowork-workspace",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "setup": "node scripts/ipollowork.mjs setup",
    "dev:cloud": "node scripts/ipollowork.mjs dev:cloud",
    "check": "node scripts/ipollowork.mjs check",
    "readme:zh-hant": "node scripts/sync-readme-zh-hant.mjs",
    "readme:zh-hant:check": "node scripts/sync-readme-zh-hant.mjs --check",
    "package": "node scripts/ipollowork.mjs package",
    "package:dir": "node scripts/ipollowork.mjs package:dir",
    "dev": "IPOLLOWORK_DEV_MODE=1 IPOLLOWORK_ELECTRON_REMOTE_DEBUG_PORT=${IPOLLOWORK_ELECTRON_REMOTE_DEBUG_PORT:-9823} pnpm --filter @ipollowork/desktop dev",
    "dev:electron": "IPOLLOWORK_DEV_MODE=1 pnpm --filter @ipollowork/desktop dev:electron",
    "dev:electron:two": "IPOLLOWORK_DEV_MODE=1 node scripts/dev-two-electron-demo.mjs",
    "demo:electron": "IPOLLOWORK_DEV_MODE=1 node scripts/dev-two-electron-demo.mjs --reset",
    "demo:electron:reset": "node scripts/dev-two-electron-demo.mjs --reset-only",
    "demo:reset": "pnpm demo:electron:reset",
    "dev:sandbox": "bash .devcontainer/dev-sandbox.sh",
    "dev:ui": "IPOLLOWORK_DEV_MODE=1 pnpm --filter @ipollowork/app dev",
    "dev:ui-demo": "pnpm --filter @ipollowork/ui-demo dev",
    "email:dev": "pnpm --filter @ipollowork/email dev",
    "dev:headless-web": "IPOLLOWORK_DEV_MODE=1 bun scripts/dev-headless-web.ts",
    "build": "node scripts/build.mjs",
    "build:ui": "pnpm --filter @ipollowork/app build",
    "preview": "pnpm --filter @ipollowork/app preview",
    "typecheck": "pnpm --filter @ipollowork/app typecheck",
    "test:health": "pnpm --filter @ipollowork/app test:health",
    "test:sessions": "pnpm --filter @ipollowork/app test:sessions",
    "test:refactor": "pnpm --filter @ipollowork/app test:refactor",
    "test:events": "pnpm --filter @ipollowork/app test:events",
    "test:todos": "pnpm --filter @ipollowork/app test:todos",
    "test:permissions": "pnpm --filter @ipollowork/app test:permissions",
    "test:session-error-recovery": "pnpm --filter @ipollowork/app test:session-error-recovery",
    "test:session-scope": "pnpm --filter @ipollowork/app test:session-scope",
    "test:session-switch": "pnpm --filter @ipollowork/app test:session-switch",
    "test:fs-engine": "pnpm --filter @ipollowork/app test:fs-engine",
    "test:e2e": "pnpm --filter @ipollowork/app test:e2e",
    "evals": "node evals/runner/run.mjs",
    "fraimz": "node evals/runner/run.mjs",
    "test:orchestrator": "pnpm --filter ipollowork-orchestrator test:router",
    "bump:patch": "pnpm --filter @ipollowork/app bump:patch",
    "bump:minor": "pnpm --filter @ipollowork/app bump:minor",
    "bump:major": "pnpm --filter @ipollowork/app bump:major",
    "bump:set": "pnpm --filter @ipollowork/app bump:set",
    "release:review": "node scripts/release/review.mjs",
    "release:prepare": "node scripts/release/prepare.mjs",
    "release:prepare:dry": "node scripts/release/prepare.mjs --dry-run",
    "release:ship": "node scripts/release/ship.mjs",
    "release:ship:watch": "node scripts/release/ship.mjs --watch"
  },
  "devDependencies": {
    "opencc-js": "^1.4.0",
    "turbo": "^2.5.5"
  },
  "packageManager": "pnpm@11.4.0"
}
