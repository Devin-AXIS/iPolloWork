FROM node:22-bookworm-slim AS ipollowork-builder

WORKDIR /src

RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates curl git unzip \
  && npm install -g bun \
  && corepack enable \
  && rm -rf /var/lib/apt/lists/*

COPY . .

RUN pnpm install --frozen-lockfile --trust-lockfile --filter ipollowork-orchestrator... --filter ipollowork-server... \
  && pnpm --filter ipollowork-orchestrator build:bin \
  && pnpm --filter ipollowork-server build:bin

FROM node:22-bookworm-slim

ARG IPOLLOWORK_ORCHESTRATOR_VERSION
ARG IPOLLOWORK_SERVER_VERSION
ARG OPENCODE_VERSION
ARG OPENCODE_DOWNLOAD_URL=

RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates curl tar unzip \
  && rm -rf /var/lib/apt/lists/*

COPY --from=ipollowork-builder /src/apps/orchestrator/dist/bin/ipollowork /usr/local/bin/ipollowork
COPY --from=ipollowork-builder /src/apps/server/dist/bin/ipollowork-server /usr/local/bin/ipollowork-server
COPY --from=ipollowork-builder /src/constants.json /usr/local/constants.json
COPY packaging/docker/microsandbox-entrypoint.sh /usr/local/bin/microsandbox-entrypoint.sh

RUN set -eux; \
  test -n "$IPOLLOWORK_ORCHESTRATOR_VERSION"; \
  test -n "$IPOLLOWORK_SERVER_VERSION"; \
  test -n "$OPENCODE_VERSION"; \
  arch="$(dpkg --print-architecture)"; \
  case "$arch" in \
    amd64) asset="opencode-linux-x64-baseline.tar.gz" ;; \
    arm64) asset="opencode-linux-arm64.tar.gz" ;; \
    *) echo "unsupported architecture: $arch" >&2; exit 1 ;; \
  esac; \
  url="$OPENCODE_DOWNLOAD_URL"; \
  if [ -z "$url" ]; then \
    url="https://github.com/anomalyco/opencode/releases/download/v${OPENCODE_VERSION}/${asset}"; \
  fi; \
  tmpdir="$(mktemp -d)"; \
  curl -fsSL "$url" -o "$tmpdir/$asset"; \
  tar -xzf "$tmpdir/$asset" -C "$tmpdir"; \
  binary="$(find "$tmpdir" -type f -name opencode | head -n 1)"; \
  test -n "$binary"; \
  install -m 0755 "$binary" /usr/local/bin/opencode; \
  chmod +x /usr/local/bin/microsandbox-entrypoint.sh; \
  rm -rf "$tmpdir"

RUN test "$(ipollowork --version)" = "$IPOLLOWORK_ORCHESTRATOR_VERSION" \
  && test "$(ipollowork-server --version)" = "$IPOLLOWORK_SERVER_VERSION" \
  && opencode --version

ENV IPOLLOWORK_DATA_DIR=/data/ipollowork-orchestrator
ENV IPOLLOWORK_SIDECAR_DIR=/data/sidecars
ENV IPOLLOWORK_WORKSPACE=/workspace

EXPOSE 8787

VOLUME ["/workspace", "/data"]

HEALTHCHECK --interval=10s --timeout=5s --start-period=20s --retries=12 \
  CMD /bin/sh -c 'curl -fsS "http://127.0.0.1:${IPOLLOWORK_PORT:-8787}/health" >/dev/null || exit 1'

ENTRYPOINT ["/usr/local/bin/microsandbox-entrypoint.sh"]
